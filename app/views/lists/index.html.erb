<!-- HERO -->
<div style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=1600');
            background-size: cover; background-position: center; height: 400px;"
     class="d-flex align-items-center justify-content-center flex-column text-white">
  <h1 class="fw-bold">Save any kind of movies</h1>
  <% if @lists.any? %>
    <p class="text-decoration-underline"><%= @lists.first.name %></p>
  <% end %>
</div>

<!-- LISTS -->
<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Lists</h2>
    <%= link_to "Create a movie list", new_list_path, class: "btn btn-success" %>
  </div>

  <div class="row g-4">
    <% @lists.each do |list| %>
      <div class="col-md-4">
        <%= link_to list_path(list), style: "text-decoration: none;" do %>
          <div style="height: 200px; border-radius: 8px; overflow: hidden; position: relative;
                      background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= list.movies.first&.poster_url %>');
                      background-size: cover; background-position: center;">
            <h4 class="text-white fw-bold position-absolute bottom-0 start-0 p-3"><%= list.name %></h4>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
